# Copy to .env on the server and fill in real values. Never commit .env.

# Leave False in production. Set True only for local development.
DJANGO_DEBUG=False

# Required when DJANGO_DEBUG=False. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Comma-separated domains the app answers on.
DJANGO_ALLOWED_HOSTS=ims.example.com,www.ims.example.com

# Comma-separated https origins, otherwise every form POST fails CSRF checks.
DJANGO_CSRF_TRUSTED_ORIGINS=https://ims.example.com,https://www.ims.example.com

# sqlite | mysql | postgresql. cPanel hosting is normally mysql.
DB_ENGINE=mysql
DB_NAME=cpaneluser_lophoroims
DB_USER=cpaneluser_lophoro
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
